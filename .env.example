# SQLite database path
DB_PATH=vulcan_notify.db

# Session file path (cookies from browser login)
# SESSION_FILE=session.json

# Auto-login credentials (optional - enables headless auth without browser)
# When set, the script auto-reauthenticates when session expires
# VULCAN_LOGIN=your.email@example.com
# VULCAN_PASSWORD=your_password

# Message sender whitelist (comma-separated, empty = show all)
# Only messages from matching senders are displayed (case-insensitive substring match)
# MESSAGE_SENDER_WHITELIST=Smith,Jones

# AI summary (optional - leave LLM_API_KEY empty to disable)
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_API_KEY=
# LLM_MODEL=qwen-3-235b-a22b-instruct-2507
# PROMPTS_FILE=prompts.toml

# ntfy.sh push notifications (used by deploy script and future notification features)
# NTFY_TOPIC=vulcan-notify
# NTFY_SERVER=https://ntfy.sh

# Logging level
LOG_LEVEL=INFO

# Polling interval in seconds (used by Docker entrypoint loop)
# POLL_INTERVAL=300

# Docker deployment: override paths to use persistent volume
# DB_PATH=/app/data/vulcan_notify.db
# SESSION_FILE=/app/data/session.json
