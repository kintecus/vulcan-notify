# eduVulcan credentials (obtained via auth flow)
# VULCAN_CREDENTIAL_FILE=credential.json

# ntfy.sh configuration
NTFY_TOPIC=vulcan-notify-CHANGE-ME
NTFY_SERVER=https://ntfy.sh

# Polling interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL=300

# SQLite database path
DB_PATH=vulcan_notify.db

# Logging level
LOG_LEVEL=INFO
